{
  "name": "@maskit/solid",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@maskit/core": "workspace:*",
    "@maskit/dom": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "vite-plugin-solid": "^2.11.11"
  }
}
